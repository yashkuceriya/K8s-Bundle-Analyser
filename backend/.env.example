# AI Analysis (optional - heuristic analysis works without these)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/k8s_analyzer

# RAG / Embeddings (optional)
OPENAI_API_KEY=

# Logging (set to "json" for structured JSON logs in production)
LOG_FORMAT=text
